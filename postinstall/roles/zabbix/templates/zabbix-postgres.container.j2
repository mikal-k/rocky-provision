[Unit]
Description=Zabbix PostgreSQL database

[Container]
Image={{ zabbix_postgres_image }}
ContainerName=zabbix-postgres
Network=zabbix.network

Volume={{ zabbix_data_dir }}/postgres:/var/lib/postgresql/data:Z,U

Secret=zabbix_db_password
Environment=POSTGRES_DB={{ zabbix_db_name }}
Environment=POSTGRES_USER={{ zabbix_db_user }}
Environment=POSTGRES_PASSWORD_FILE=/run/secrets/zabbix_db_password
Environment=TZ={{ zabbix_timezone }}

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
